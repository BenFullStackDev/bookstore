@page "/myorders"
@using Microsoft.EntityFrameworkCore
@using Bookstore.Models
@using Bookstore.Data
@inject IDbContextFactory<BookstoreDb> DbFactory
@implements IAsyncDisposable

<PageTitle>Bookstore - My Orders</PageTitle>

<div class="container mt-4">
    @if (orders is null)
    {
        <p>Loading...</p>
    }
    else if (!orders.Any())
    {
        <p>No orders found.</p>
    }
    else
    {
        @foreach (var order in orders)
        {
            <div class="order-container border-bottom pb-4 mb-4">
                <h3>@order.OrderDate.ToString("MMMM d, yyyy")</h3>
                <div class="mt-3">
                    @foreach (var item in order.OrderItems)
                    {
                        <div class="row mb-2">
                            <div class="col-sm-5 col-md-4">
                                <strong>@item.Book.Title (@item.Quantity):</strong>
                            </div>
                            <div class="col-sm-7 col-md-8">
                                @item.GetTotal().ToString("C")
                            </div>
                        </div>
                    }
                </div>
                <div class="mt-4 text-muted">
                    <small>Total (@order.OrderItems.Count) : @order.GetTotal().ToString("C")</small>
                </div>
            </div>
        }
    }
</div>

@code {
    private BookstoreDb context { get; set; }
    private IEnumerable<Order> orders;

    protected override async Task OnInitializedAsync()
    {
        context = await DbFactory.CreateDbContextAsync();
        orders = await context.Orders
            .Include(o => o.OrderItems)
            .ThenInclude(i => i.Book)
            .OrderByDescending(o => o.OrderDate)
            .ToListAsync();
    }

    public async ValueTask DisposeAsync() => await context.DisposeAsync();
}
